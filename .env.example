# Copy to ".env" and adjust. Vite only exposes variables prefixed with VITE_.

# REST API base URL for axios.
# Local dev: "/api" uses vite.config.js proxy → http://localhost:5000
# Production: full URL, e.g. https://api.yourdomain.com/api
VITE_API_BASE_URL=/api

# Socket.io server origin (scheme + host + port, no path). Must match your backend.
# Local dev default in code is localhost:5000 if unset.
VITE_SOCKET_URL=http://localhost:5000
